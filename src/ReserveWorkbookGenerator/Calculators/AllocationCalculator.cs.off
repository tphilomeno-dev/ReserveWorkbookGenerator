using ReserveWorkbookGenerator.Common;
using ReserveWorkbookGenerator.Models;

namespace ReserveWorkbookGenerator.Calculators;

public class AllocationCalculator
{
    public void Execute(
        IList<ReserveComponent> components,
        decimal beginningReservePool)
    {
        if (components == null)
            throw new ArgumentNullException(nameof(components));

        if (!components.Any())
            return;

        decimal totalFfb = components.Sum(c => c.FFB);

        if (totalFfb <= 0)
            return;

        foreach (var component in components)
        {
            component.FfbWeight =
                Money.Divide(component.FFB, totalFfb);

            component.BeginningAllocation =
                Money.Round(beginningReservePool * component.FfbWeight);
        }
    }
}